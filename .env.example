# ── Core LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REVIEW_MODEL=gpt-4o

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=genpal-prototype

# ── App behaviour ─────────────────────────────────────────────────────────────
USE_MOCK_DATA=true
DUPLICATE_SIMILARITY_THRESHOLD=0.88

# ── URLs ──────────────────────────────────────────────────────────────────────
# Base URL of the Streamlit app (used in SME review links)
APP_BASE_URL=http://localhost:8501
# FastAPI backend URL (Streamlit reads this to know where to send API calls)
BACKEND_URL=http://localhost:8000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite default. Override for production.
DATABASE_URL=sqlite:///./genpal.db

# ── Generation tuning ─────────────────────────────────────────────────────────
MAX_CANDIDATE_ROUNDS_PER_BATCH=3
MAX_DUPLICATE_PASSES_PER_LEVEL=3
MAX_REWORK_ATTEMPTS_PER_ROW=3
MAX_FINAL_DUPLICATE_REPAIR_PASSES=3
MAX_FINAL_REWORK_ATTEMPTS_PER_ROW=3

# ── SME review ────────────────────────────────────────────────────────────────
REVIEW_TOKEN_EXPIRY_HOURS=72

# ── Web search for doc discovery (requires OpenAI responses API) ───────────────
ENABLE_OPENAI_WEB_SEARCH=false

# ── OpenAI cost tracking (per 1M tokens, USD) ─────────────────────────────────
OPENAI_INPUT_PRICE_PER_1M=2.50
OPENAI_OUTPUT_PRICE_PER_1M=10.00
OPENAI_EMBEDDING_PRICE_PER_1M=0.02

# ── Email (optional — leave blank for link-copy-only mode) ───────────────────
# Provider: smtp | sendgrid
EMAIL_PROVIDER=
EMAIL_FROM=genpal@example.com

# SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SendGrid settings
SENDGRID_API_KEY=

# ── Legacy (kept for backward compat) ─────────────────────────────────────────
APP_PASSWORD=
