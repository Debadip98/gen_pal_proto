# ── URLs (Apache-hosted frontend + FastAPI backend) ──────────────────────────
# APP_BASE_URL is where the static frontend is served by Apache. It is used to
# build the SME review link (e.g. http://localhost:8080/#/review?review_token=...).
APP_BASE_URL=http://localhost:8080
# Direct URL of the FastAPI backend (used only for direct/local testing; through
# Apache the browser uses relative /api paths).
API_BASE_URL=http://127.0.0.1:8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./genpal_prototype.db

# ── Core LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REVIEW_MODEL=gpt-4o
ENABLE_OPENAI_WEB_SEARCH=false

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=genpal-prototype

# ── App behaviour ─────────────────────────────────────────────────────────────
# When true, the app runs without calling OpenAI (deterministic mock data).
USE_MOCK_DATA=true
DUPLICATE_SIMILARITY_THRESHOLD=0.88

# ── Email (optional — leave blank for link-copy-only mode) ───────────────────
# Provider: smtp | sendgrid
EMAIL_PROVIDER=
EMAIL_FROM=genpal@example.com
# SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SendGrid settings
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── SME review ────────────────────────────────────────────────────────────────
REVIEW_TOKEN_EXPIRY_HOURS=72

# ── OpenAI cost tracking (per 1M tokens, USD) ─────────────────────────────────
OPENAI_GENERATION_INPUT_PRICE_PER_1M=2.50
OPENAI_GENERATION_OUTPUT_PRICE_PER_1M=10.00
OPENAI_EMBEDDING_PRICE_PER_1M=0.02

# ── Generation tuning ─────────────────────────────────────────────────────────
MAX_CANDIDATE_ROUNDS_PER_BATCH=3
MAX_DUPLICATE_PASSES_PER_LEVEL=3
MAX_REWORK_ATTEMPTS_PER_ROW=3
MAX_FINAL_DUPLICATE_REPAIR_PASSES=3
MAX_FINAL_REWORK_ATTEMPTS_PER_ROW=3
