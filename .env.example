# ── Local demo ────────────────────────────────────────────────────────────────
# FastAPI serves BOTH the API and the static frontend on one origin.
# Run:  uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000
# Open: http://127.0.0.1:8000
APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./genpal_prototype.db

# ── Demo / mock mode ──────────────────────────────────────────────────────────
# true  -> no OpenAI calls; deterministic sample questions (default for demo)
# false -> requires OPENAI_API_KEY (clear error if missing; no crash)
USE_MOCK_DATA=true

# ── Core LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REVIEW_MODEL=gpt-4o
ENABLE_OPENAI_WEB_SEARCH=false

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=genpal-prototype

# ── Duplicate detection ───────────────────────────────────────────────────────
DUPLICATE_SIMILARITY_THRESHOLD=0.85
FUZZY_DUPLICATE_THRESHOLD=90

# ── OpenAI cost tracking (per 1M tokens, USD) — blank = use safe defaults ──────
OPENAI_GENERATION_INPUT_PRICE_PER_1M=
OPENAI_GENERATION_OUTPUT_PRICE_PER_1M=
OPENAI_EMBEDDING_PRICE_PER_1M=

# ── Email (optional — blank = show review link in UI instead of sending) ──────
EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── SME review ────────────────────────────────────────────────────────────────
REVIEW_TOKEN_EXPIRY_HOURS=72
